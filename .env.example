# Provider: openai (default) ou xai (Grok Voice)
VOICE_PROVIDER=openai

# Clés API (selon le provider choisi)
OPENAI_API_KEY=sk-...
XAI_API_KEY=

# Modèle OpenAI Realtime : gpt-realtime-mini | gpt-realtime | gpt-realtime-2
OPENAI_REALTIME_MODEL=gpt-realtime-mini

# Modèle xAI Grok Voice (seul grok-voice-think-fast-1.0 est supporté)
GROK_MODEL=grok-voice-think-fast-1.0

# Reasoning effort (gpt-realtime / gpt-realtime-2 uniquement) : minimal | low | medium | high
OPENAI_REASONING_EFFORT=medium

# Voix OpenAI : alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar
OPENAI_REALTIME_VOICE=alloy

# Voix xAI Grok : eve, ara, rex, sal, leo
GROK_VOICE=eve

# IP du Reachy Mini sur le LAN. Vide = auto-détection (USB ou mDNS reachy-mini.local).
# Sur WSL2, le mDNS ne marche généralement pas — récupérer l'IP via PowerShell : `ping reachy-mini.local`.
REACHY_HOST=
REACHY_PORT=8000

# ---- Vision (optionnel) ----
# Vide / non défini = vision désactivée (l'agent reste audio-only).
# Choix : moondream | fastvlm | none
VISION_BACKEND=

# Moondream cloud (recommandé pour démarrer) — clé sur https://moondream.ai/c/account/api-keys
MOONDREAM_API_KEY=
# Mettre à 1 pour charger le modèle en local (extra `moondream` requis).
# Déconseillé sur le Pi (8–20 s/query). À utiliser sur Mac / laptop CUDA.
#MOONDREAM_LOCAL=0

# FastVLM-7B servi par Colab (voir colab/fastvlm_7b_server.ipynb).
# Coller l'URL trycloudflare.com imprimée par la dernière cellule du notebook.
#FASTVLM_URL=https://xxxx.trycloudflare.com
#FASTVLM_TIMEOUT=30
