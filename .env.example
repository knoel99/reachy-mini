OPENAI_API_KEY=sk-...

# OpenAI Realtime model. Options (USD per 1M tokens):
#   gpt-realtime-mini  text in 0.60  / out  2.40   audio in 10 / out 20
#                      Cheapest. No reasoning.effort. Weakest planner.
#   gpt-realtime       text in 4.00  / out 16.00   audio in 32 / out 64
#                      Supports reasoning.effort. Strong tool use.
#   gpt-realtime-2     text in 4.00  / out 24.00   audio in 32 / out 64
#                      Latest full model. Supports reasoning.effort.
#                      Best at multi-step planning ("imitate a chicken",
#                      "draw a circle with your head", "dance"…).
#
# Override at runtime without editing this file:
#   ./run.sh mini | full | full2     (shorthands)
#   python main.py --model <id>      (explicit)
OPENAI_REALTIME_MODEL=gpt-realtime-mini

# Reasoning effort. Used only for gpt-realtime / gpt-realtime-2.
# Values: minimal | low | medium | high
# Higher = better planning, but more latency and tokens.
OPENAI_REASONING_EFFORT=medium

# Voice (GA): alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar
OPENAI_REALTIME_VOICE=alloy

# IP du Reachy Mini sur le LAN. Laisser vide pour auto-détection
# (USB ou mDNS reachy-mini.local). Sur WSL2, le mDNS ne marche
# généralement pas — récupérer l'IP via PowerShell : `ping reachy-mini.local`.
REACHY_HOST=
REACHY_PORT=8000

